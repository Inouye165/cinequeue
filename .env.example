# Cinequeue Configuration
# Copy this file to .env and fill in your actual values
# .env is gitignored and should never be committed

# TMDB API Configuration
TMDB_API_KEY=your_tmdb_api_key_here

# Data Storage
DATA_DIR=./data

# Backend Configuration
BACKEND_PORT=8001
BACKEND_HOST=127.0.0.1

# Frontend Configuration
FRONTEND_PORT=5180

# Watchlist Storage Backend
# "sqlite" (default, for local dev) or "firestore" (production Cloud Run)
# WATCHLIST_BACKEND=sqlite

# Google Cloud Project (used by Firestore client when WATCHLIST_BACKEND=firestore)
# GOOGLE_CLOUD_PROJECT=cinequeue-inouye-2026

# Environment & Authentication
ENVIRONMENT=development
AUTH_ENABLED=false
AUTH_MODE=allowlist
AUTH_ALLOWED_EMAILS=inouye165@gmail.com
AUTH_ALLOWED_ORIGINS=http://localhost:5180,http://127.0.0.1:5180,http://localhost:8080,http://127.0.0.1:8080,https://cinequeue-568212960791.us-west1.run.app
FIREBASE_PROJECT_ID=cinequeue-inouye-2026
FIREBASE_API_KEY=your_firebase_api_key_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
SESSION_COOKIE_DAYS=5
SESSION_COOKIE_SECURE=false

# --- Authentication Performance Monitoring ---
# Set to true to enable the development diagnostics tracing overlay on the frontend
VITE_AUTH_PERFORMANCE_DEBUG=false
# Set to true to print detailed timing logs for /api/admin/me requests on the backend
AUTH_PERFORMANCE_DEBUG=false

