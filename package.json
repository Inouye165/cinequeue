{
  "name": "cinequeue",
  "version": "1.0.0",
  "description": "Cinequeue root workspace",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd frontend && npm install",
    "dev": "concurrently --kill-others -n \"backend,frontend\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --port 8081",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
